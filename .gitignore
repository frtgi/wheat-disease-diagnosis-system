# ===========================================
# WheatAgent 项目 Git 忽略文件配置
# ===========================================

# ===========================================
# 敏感配置文件（防止密钥泄露）
# ===========================================
.env
.env.local
.env.development
.env.production
.env.test
*.pem
*.key
*.crt
secret.yaml
secrets.yaml
credentials.json
service-account.json

# ===========================================
# Python
# ===========================================
# 字节码文件
__pycache__/
*.py[cod]
*$py.class
*.so

# 构建目录
build/
dist/
*.egg-info/
*.egg

# 类型检查
.pytype/
.pyre/

# 虚拟环境
venv/
env/
ENV/
.venv
.python-version

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# 测试
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Jupyter Notebook
.ipynb_checkpoints

# ===========================================
# 数据库文件
# ===========================================
*.db
*.sqlite
*.sqlite3
data/*.db
data/*.sqlite

# ===========================================
# 日志文件
# ===========================================
logs/
*.log
log/

# ===========================================
# 上传文件
# ===========================================
uploads/
upload/
temp/
tmp/

# ===========================================
# 模型文件（如果不需要版本控制）
# ===========================================
models/
model/
checkpoints/
weights/
*.pth
*.pt
*.onnx
*.h5

# 但保留 .gitkeep 以保持目录结构
!models/.gitkeep
!checkpoints/.gitkeep

# ===========================================
# 导出数据和结果
# ===========================================
exports/
results/
output/

# ===========================================
# 前端
# ===========================================
# 依赖
node_modules/
npm-debug.log
yarn-error.log

# 构建输出
dist/
build/

# 环境变量
src/web/frontend/.env
src/web/frontend/.env.local
src/web/frontend/.env.production

# ===========================================
# 文档生成
# ===========================================
docs/_build/
docs/.doctrees/

# ===========================================
# 系统文件
# ===========================================
.DS_Store
Thumbs.db
desktop.ini

# ===========================================
# 特定于项目的忽略
# ===========================================
# CUDA 和 GPU 相关
*.cu
*.cubin
*.fatbin

# Neo4j 数据
neo4j/data/

# Redis 数据
dump.rdb
appendonly.aof

# ===========================================
# 保留必要的 .gitkeep 文件
# ===========================================
!.gitkeep
!**/.gitkeep
