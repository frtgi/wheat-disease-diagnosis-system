# WheatAgent 前端 npm 安全配置
# ============================================

# 强制使用 HTTPS 协议访问注册表，防止中间人攻击
protocol=https

# 使用官方 npm 源（国内可替换为淘宝镜像）
registry=https://registry.npmmirror.com/

# 安全审计相关配置
# 启用严格 SSL 验证
strict-ssl=true

# 禁止脚本执行（降低供应链攻击风险）
# 取消注释以下行可在安装时禁用所有生命周期脚本
# ignore-scripts=true

# 仅允许指定包执行脚本（白名单方式）
# allow-same-version=true

# 依赖锁定配置
# 确保 package-lock.json 格式版本一致
lockfile-version=3

# 防止意外发布私有包
//registry.npmjs.org/:_authToken=

# 引擎严格检查
engine-strict=true

# 超时设置（毫秒）
fetch-timeout=120000
fetch-retries=3
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=60000

# 最大 socket 数量
maxsockets=50
