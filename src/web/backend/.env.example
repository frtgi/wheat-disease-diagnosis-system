# 基于多模态融合的小麦病害诊断系统 - 后端环境配置示例文件
# 使用说明：
# 1. 复制此文件为 .env
# 2. 修改所有 <CHANGE_ME> 占位符为实际值
# 3. 切勿将 .env 文件提交到版本控制

# ===========================================
# 数据库连接配置
# ===========================================
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
DATABASE_NAME=wheat_agent_db

# 数据库连接字符串（自动生成，勿直接使用）
# 格式：mysql+aiomysql://用户:密码@主机:端口/数据库
# DATABASE_URL=mysql+aiomysql://root:<PASSWORD>@127.0.0.1:3306/wheat_agent_db

# ===========================================
# Redis 配置
# ===========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=<CHANGE_ME_OR_LEAVE_EMPTY>

# ===========================================
# JWT 配置 - 重要安全设置
# ===========================================
# 生成强密钥命令：
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# 或者在 Python 环境中执行：
# import secrets; secrets.token_urlsafe(32)
JWT_SECRET_KEY=<CHANGE_ME_GENERATE_STRONG_KEY>
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ===========================================
# CORS 配置 - 重要安全设置
# ===========================================
# 允许的前端域名列表（逗号分隔）
# 生产环境必须配置为实际的前端域名，切勿使用通配符 "*"
# 示例：CORS_ORIGINS=https://example.com,https://www.example.com
# 开发环境示例：
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 生产环境示例：
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# 注意：使用通配符 "*" 会导致安全警告并被自动移除

# ===========================================
# 应用配置
# ===========================================
APP_NAME=WheatAgent Web Backend
APP_ENV=development
DEBUG=False

# ===========================================
# MinIO 对象存储配置（可选）
# ===========================================
# 生产环境请使用强密钥
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=<CHANGE_ME_STRONG_ACCESS_KEY>
MINIO_SECRET_KEY=<CHANGE_ME_STRONG_SECRET_KEY>
MINIO_BUCKET=wheat-agent

# ===========================================
# Neo4j 图数据库配置
# ===========================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<CHANGE_ME_NEO4J_PASSWORD>
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30

# ===========================================
# 推理缓存配置
# ===========================================
# 缓存过期时间（秒），默认 24 小时
INFERENCE_CACHE_TTL=86400
# 是否启用相似图像搜索
INFERENCE_CACHE_ENABLE_SIMILAR_SEARCH=true
# 相似度阈值（汉明距离），值越小越严格
INFERENCE_CACHE_SIMILARITY_THRESHOLD=5
# 是否启用推理缓存
INFERENCE_CACHE_ENABLED=true

# ===========================================
# 安全提示
# ===========================================
# 1. 生产环境必须修改所有默认密码
# 2. JWT_SECRET_KEY 必须使用强随机密钥
# 3. 数据库密码应使用强密码（至少 12 位，包含大小写、数字、特殊字符）
# 4. .env 文件不应提交到版本控制系统
# 5. 定期更新密钥和密码

# ===========================================
# Celery 任务队列配置
# ===========================================
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=Asia/Shanghai

# ===========================================
# SlowAPI 限流配置
# ===========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_DIAGNOSIS=10/minute
RATE_LIMIT_UPLOAD=20/minute
